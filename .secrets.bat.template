@echo off
REM Copy this file to .secrets.bat and fill in your real values.
REM .secrets.bat is gitignored and never committed.
REM
REM ── Dev host ─────────────────────────────────────────────────────────────────
REM Options:
REM   localhost          — single machine only (Google OAuth works)
REM   192.168.x.x        — LAN testing from phone/tablet (Google OAuth blocked by Google)
REM   dev.yourdomain.com — custom domain (Google OAuth works if added to Console)
set DEV_HOST=localhost
REM
REM ── AI / LLM ──────────────────────────────────────────────────────────────────
REM Free tier at https://openrouter.ai — no billing required for free models
REM (meta-llama/llama-3.1-8b-instruct:free is used by default on dev profile)
set OPENROUTER_API_KEY=<your-openrouter-api-key>
REM
REM Google OAuth — https://console.cloud.google.com/apis/credentials
set GOOGLE_CLIENT_ID=<your-google-client-id>
set GOOGLE_CLIENT_SECRET=<your-google-client-secret>
REM
REM Microsoft OAuth — https://portal.azure.com/ -> App Registrations
set MICROSOFT_CLIENT_ID=<your-microsoft-client-id>
set MICROSOFT_CLIENT_SECRET=<your-microsoft-client-secret>
REM
REM ── Firebase (phone OTP verification) ─────────────────────────────────────────
REM Required for phone number verification on the Profile page.
REM Create a Firebase project at https://console.firebase.google.com, enable
REM Authentication → Phone, then copy the values from Project Settings → General.
set NEXT_PUBLIC_FIREBASE_API_KEY=<your-firebase-api-key>
set NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<your-project>.firebaseapp.com
set NEXT_PUBLIC_FIREBASE_PROJECT_ID=<your-project-id>
set NEXT_PUBLIC_FIREBASE_APP_ID=<your-firebase-app-id>
