      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT toStartOfHour(completed_at) AS time, quantile(0.50)(latency_ms) AS p50, quantile(0.95)(latency_ms) AS p95, quantile(0.99)(latency_ms) AS p99 FROM aegispay_analytics.saga_latencies WHERE completed_at >= now() - INTERVAL 7 DAY GROUP BY time ORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisLabel": "", "axisPlacement": "auto", "drawStyle": "bars", "fillOpacity": 80, "gradientMode": "none", "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" } },
