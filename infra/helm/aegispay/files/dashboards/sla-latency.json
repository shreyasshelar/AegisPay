      "title": "P95 Saga Latency (24 h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT quantile(0.95)(latency_ms) AS p95 FROM aegispay_analytics.saga_latencies WHERE completed_at >= now() - INTERVAL 24 HOUR",
          "refId": "A",
          "format": "table"
