        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "auto", "displayMode": "color-background" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10000 }, { "color": "red", "value": 30000 }] }, "unit": "ms" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "transaction_id" }, "properties": [{ "id": "custom.width", "value": 300 }] },
          { "matcher": { "id": "byName", "options": "latency_ms" }, "properties": [{ "id": "custom.width", "value": 130 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "id": 7,
      "options": { "footer": { "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true, "sortBy": [{ "displayName": "latency_ms", "desc": true }] },
      "title": "Slowest Sagas (last 24 h)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT toString(transaction_id) AS transaction_id, latency_ms, final_status, completed_at FROM aegispay_analytics.saga_latencies WHERE completed_at >= now() - INTERVAL 24 HOUR ORDER BY latency_ms DESC LIMIT 20",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "auto", "displayMode": "auto" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "transaction_id" }, "properties": [{ "id": "custom.width", "value": 300 }] },
          { "matcher": { "id": "byName", "options": "break_type" }, "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "amount_diff" }, "properties": [{ "id": "unit", "value": "currencyINR" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "id": 8,
      "options": { "footer": { "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true, "sortBy": [{ "displayName": "detected_at", "desc": true }] },
