      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT toStartOfHour(completed_at) AS time, final_status, count() AS cnt FROM aegispay_analytics.saga_latencies WHERE completed_at >= now() - INTERVAL 7 DAY GROUP BY time, final_status ORDER BY time",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
