  ],
  "annotations": { "list": [] },
  "description": "AegisPay — Payment Operations: volume, success/failure rates, failure codes, hourly trends",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Transactions (24 h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT count() AS total FROM aegispay_analytics.transaction_facts WHERE event_time >= now() - INTERVAL 24 HOUR",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Failure Rate (24 h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT round(countIf(status = 'FAILED') * 100.0 / count(), 2) AS failure_rate FROM aegispay_analytics.transaction_facts WHERE event_time >= now() - INTERVAL 24 HOUR",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "currencyINR"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Volume INR (24 h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT sum(amount) AS volume FROM aegispay_analytics.transaction_facts WHERE event_time >= now() - INTERVAL 24 HOUR AND currency = 'INR'",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Completed (24 h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT countIf(status = 'COMPLETED') AS completed FROM aegispay_analytics.transaction_facts WHERE event_time >= now() - INTERVAL 24 HOUR",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "bars", "fillOpacity": 80, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "normal" }, "thresholdsStyle": { "mode": "off" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Transaction Count by Status — Hourly",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "bars", "fillOpacity": 85, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "normal" }, "thresholdsStyle": { "mode": "off" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "COMPLETED" },    "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "FAILED" },       "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "ROLLED_BACK" },  "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT toStartOfHour(event_time) AS time, status, count() AS cnt FROM aegispay_analytics.transaction_facts WHERE event_time >= now() - INTERVAL 7 DAY GROUP BY time, status ORDER BY time",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "mappings": [],
          "unit": "currencyINR"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "id": 6,
      "options": { "displayLabels": ["percent", "name"], "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "pieType": "donut", "tooltip": { "mode": "single", "sort": "none" } },
      "title": "Volume by Currency (24 h)",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT currency, sum(amount) AS volume FROM aegispay_analytics.transaction_facts WHERE event_time >= now() - INTERVAL 24 HOUR GROUP BY currency ORDER BY volume DESC",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "auto", "displayMode": "auto" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 80 }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "count" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "failure_code" }, "properties": [{ "id": "custom.width", "value": 220 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "options": { "footer": { "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true, "sortBy": [{ "displayName": "count", "desc": true }] },
      "title": "Top Failure Codes (24 h)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT failure_code, count() AS count FROM aegispay_analytics.transaction_facts WHERE event_time >= now() - INTERVAL 24 HOUR AND status = 'FAILED' AND failure_code != '' GROUP BY failure_code ORDER BY count DESC LIMIT 20",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisLabel": "", "axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none", "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" } },
          "mappings": [],
          "unit": "currencyINR"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "Hourly Transaction Volume by Currency",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "aegispay-clickhouse" },
          "rawSql": "SELECT toStartOfHour(event_time) AS time, currency, sum(amount) AS volume FROM aegispay_analytics.transaction_facts WHERE event_time >= now() - INTERVAL 7 DAY GROUP BY time, currency ORDER BY time",
          "refId": "A",
          "format": "table"
        }
      ]
    }
  ],
