      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Test@1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "CUSTOMER",
        "offline_access"
      ],
      "attributes": {
        "aegispay_role": [
          "CUSTOMER"
        ],
        "aegispay_tenant_id": [
          "default"
        ]
      },
      "id": "59295e61-a284-40ed-8d3b-9e15bedeb040"
    },
    {
      "username": "admin@aegispay.local",
      "email": "admin@aegispay.local",
      "firstName": "Test",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Admin@1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN",
        "offline_access"
      ],
      "attributes": {
        "aegispay_role": [
          "ADMIN"
        ],
        "aegispay_tenant_id": [
          "default"
        ]
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    },
    {
      "id": "3bf3e523-9de8-4254-9cc9-d5fa50ff8d4a",
