{
  "realm": "aegispay",
  "enabled": true,
  "displayName": "AegisPay",
  "accessTokenLifespan": 3600,
  "ssoSessionMaxLifespan": 86400,

  "clients": [
    {
      "clientId": "aegispay-web",
      "name": "AegisPay Web App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:3001"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "openid", "profile", "email", "roles", "web-origins", "aegispay-claims"
      ],
      "optionalClientScopes": ["offline_access"]
    },
    {
      "clientId": "aegispay-mobile",
      "name": "AegisPay Mobile App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "com.aegispay.app://callback",
        "com.aegispay.android://oauth/callback",
        "exp://localhost:8081"
      ],
      "webOrigins": ["*"],
      "defaultClientScopes": [
        "openid", "profile", "email", "roles", "aegispay-claims"
      ],
      "optionalClientScopes": ["offline_access"]
    },
    {
      "clientId": "aegispay-backend",
      "name": "AegisPay Backend (service-to-service)",
      "enabled": true,
      "publicClient": false,
      "secret": "aegispay-backend-dev-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false
    }
  ],

  "roles": {
    "realm": [
      { "name": "CUSTOMER",     "description": "End user customer" },
      { "name": "MERCHANT_OPS", "description": "Merchant operations" },
      { "name": "BACK_OFFICE",  "description": "Back-office agent" },
      { "name": "ADMIN",        "description": "System administrator" },
      { "name": "PARTNER",      "description": "External partner" }
    ]
  },

  "users": [
    {
      "id": "59295e61-a284-40ed-8d3b-9e15bedeb040",
      "username": "customer@aegispay.local",
      "email": "customer@aegispay.local",
      "firstName": "Test",
      "lastName": "Customer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "Test@1234", "temporary": false }],
      "realmRoles": ["CUSTOMER"],
      "attributes": {
        "aegispay_role":      ["CUSTOMER"],
        "aegispay_tenant_id": ["default"]
      }
    },
    {
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "username": "admin@aegispay.local",
      "email": "admin@aegispay.local",
      "firstName": "Test",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "Admin@1234", "temporary": false }],
      "realmRoles": ["ADMIN"],
      "attributes": {
        "aegispay_role":      ["ADMIN"],
        "aegispay_tenant_id": ["default"]
      }
    },
    {
      "id": "3bf3e523-9de8-4254-9cc9-d5fa50ff8d4a",
      "username": "payee@aegispay.local",
      "email": "payee@aegispay.local",
      "firstName": "Test",
      "lastName": "Payee",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "Test@1234", "temporary": false }],
      "realmRoles": ["CUSTOMER"],
      "attributes": {
        "aegispay_role":      ["CUSTOMER"],
        "aegispay_tenant_id": ["default"]
      }
    }
  ],

  "clientScopes": [
    {
      "name": "aegispay-claims",
      "description": "AegisPay custom JWT claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "aegispay_role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute":       "aegispay_role",
            "claim.name":           "aegispay_role",
            "jsonType.label":       "String",
            "id.token.claim":       "true",
            "access.token.claim":   "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "aegispay_tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute":       "aegispay_tenant_id",
            "claim.name":           "aegispay_tenant_id",
            "jsonType.label":       "String",
            "id.token.claim":       "true",
            "access.token.claim":   "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "aegispay_user_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute":       "aegispay_user_id",
            "claim.name":           "aegispay_user_id",
            "jsonType.label":       "String",
            "id.token.claim":       "true",
            "access.token.claim":   "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],

  "defaultDefaultClientScopes": [
    "openid", "profile", "email", "roles", "web-origins", "aegispay-claims"
  ],
  "defaultOptionalClientScopes": [
    "offline_access"
  ],

  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "aegispay-social-first-login",
      "config": {
        "clientId":     "${GOOGLE_CLIENT_ID:placeholder}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET:placeholder}",
        "hostedDomain": "",
        "syncMode":     "IMPORT"
      }
    },
    {
      "alias": "microsoft",
      "displayName": "Microsoft",
      "providerId": "microsoft",
      "enabled": true,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "aegispay-social-first-login",
      "config": {
        "clientId":     "${MICROSOFT_CLIENT_ID:placeholder}",
        "clientSecret": "${MICROSOFT_CLIENT_SECRET:placeholder}",
        "tenant":       "common",
        "syncMode":     "IMPORT"
      }
    }
  ],

  "identityProviderMappers": [
    {
      "name":                   "google-set-tenant",
      "identityProviderAlias":  "google",
      "identityProviderMapper": "hardcoded-attribute-idp-mapper",
      "config": { "attribute": "aegispay_tenant_id", "attribute.value": "default", "syncMode": "INHERIT" }
    },
    {
      "name":                   "google-set-role",
      "identityProviderAlias":  "google",
      "identityProviderMapper": "hardcoded-attribute-idp-mapper",
      "config": { "attribute": "aegispay_role", "attribute.value": "CUSTOMER", "syncMode": "INHERIT" }
    },
    {
      "name":                   "google-assign-realm-role",
      "identityProviderAlias":  "google",
      "identityProviderMapper": "hardcoded-role-idp-mapper",
      "config": { "role": "CUSTOMER", "syncMode": "INHERIT" }
    },
    {
      "name":                   "microsoft-set-tenant",
      "identityProviderAlias":  "microsoft",
      "identityProviderMapper": "hardcoded-attribute-idp-mapper",
      "config": { "attribute": "aegispay_tenant_id", "attribute.value": "default", "syncMode": "INHERIT" }
    },
    {
      "name":                   "microsoft-set-role",
      "identityProviderAlias":  "microsoft",
      "identityProviderMapper": "hardcoded-attribute-idp-mapper",
      "config": { "attribute": "aegispay_role", "attribute.value": "CUSTOMER", "syncMode": "INHERIT" }
    },
    {
      "name":                   "microsoft-assign-realm-role",
      "identityProviderAlias":  "microsoft",
      "identityProviderMapper": "hardcoded-role-idp-mapper",
      "config": { "role": "CUSTOMER", "syncMode": "INHERIT" }
    }
  ],

  "authenticatorConfig": [
    {
      "alias": "review-profile-auto",
      "config": {
        "update.profile.on.first.login": "missing"
      }
    }
  ],

  "authenticationFlows": [
    {
      "alias": "aegispay-social-first-login",
      "description": "First-broker-login for social IdPs — skips profile review, auto-links on email match",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "flowAlias": "aegispay-social-review-profile",
          "userSetupAllowed": false,
          "priority": 0
        }
      ]
    },
    {
      "alias": "aegispay-social-review-profile",
      "description": "Auto-confirm profile, then create or link account",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "idp-review-profile",
          "authenticatorConfig": "review-profile-auto",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 0
        },
        {
          "authenticator": "idp-auto-link",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 1
        },
        {
          "authenticator": "idp-create-user-if-unique",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 2
        }
      ]
    }
  ]
}
