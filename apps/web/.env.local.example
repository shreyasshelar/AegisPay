# ─── NextAuth ───────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_32_BYTE_SECRET

# ─── Keycloak (primary IdP — started by docker compose) ─────────────────────
KEYCLOAK_ID=aegispay-web
# For local dev with the docker compose realm the client is public (no secret needed).
# Leave blank or set to the Keycloak client secret if you use a confidential client.
KEYCLOAK_SECRET=
# Keycloak realm URL (must match realm-export.json → realm: "aegispay")
KEYCLOAK_ISSUER=http://localhost:8180/realms/aegispay

# ─── Backend API (via API Gateway on port 8080) ──────────────────────────────
# All REST calls are routed through the API Gateway.
# No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ─── WebSocket (notification-service — port 8086) ───────────────────────────
# STOMP-over-WebSocket endpoint used for real-time transaction status updates.
# In prod this is proxied through the API Gateway (ws://api.aegispay.io/ws).
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8086
