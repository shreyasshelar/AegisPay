# ─── NextAuth ───────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_32_BYTE_SECRET

# ─── Keycloak (primary IdP) ──────────────────────────────────────────────────
KEYCLOAK_ID=aegispay-web
KEYCLOAK_SECRET=REPLACE_WITH_CLIENT_SECRET
# e.g. https://auth.example.com/realms/aegispay
KEYCLOAK_ISSUER=http://localhost:8180/realms/aegispay

# ─── Backend API ─────────────────────────────────────────────────────────────
# Base URL for REST calls (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# WebSocket base URL for STOMP over WS
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8090
