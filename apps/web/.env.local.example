# ─── Node.js DNS — prefer IPv4 so localhost resolves to 127.0.0.1 not ::1 ──
NODE_OPTIONS=--dns-result-order=ipv4first

# ─── NextAuth ───────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_32_BYTE_SECRET

# ─── Keycloak (primary IdP — started by docker compose) ─────────────────────
KEYCLOAK_ID=aegispay-web
# For local dev with the docker compose realm the client is public (no secret needed).
# Leave blank or set to the Keycloak client secret if you use a confidential client.
KEYCLOAK_SECRET=
# Keycloak realm URL (must match realm-export.json → realm: "aegispay")
KEYCLOAK_ISSUER=http://localhost:8180/realms/aegispay

# ─── Backend API (via Next.js rewrite proxy — keeps browser calls same-origin) ─
# Empty = browser calls /api/v1/* (same-origin); Next.js rewrites to API_BASE_URL.
NEXT_PUBLIC_API_BASE_URL=
# Server-side rewrite target (never sent to browser)
API_BASE_URL=http://localhost:8080

# ─── WebSocket (notification-service — port 8086) ───────────────────────────
# STOMP-over-WebSocket endpoint used for real-time transaction status updates.
# In prod this is proxied through the API Gateway (ws://api.aegispay.io/ws).
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8086

# ─── Firebase Phone Auth (OTP verification only) ────────────────────────────
# Used ONLY for phone number OTP verification in the Profile page.
# Keycloak handles all primary auth — Firebase session is signed out immediately
# after OTP verification succeeds.
#
# Get these values from: Firebase Console → Project Settings → General → Your apps → Web app
# Required: all four must be set or Firebase phone auth is disabled (graceful no-op).
#
# ⚠️  IMPORTANT — reCAPTCHA Enterprise:
#   Firebase v10 projects enrolled in reCAPTCHA Enterprise need the
#   initializeRecaptchaConfig() call (already in profile-client.tsx) to tell
#   the SDK which token format to use.  Without it real numbers fail with
#   auth/invalid-app-credential even when all authorized domains are set.
#
#   If real SMS still fails after setting these vars:
#   Firebase Console → Authentication → Sign-in method → Phone → check
#   reCAPTCHA configuration and ensure phone auth is enabled.
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_WITH_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
#
# ── Local dev only — set to true to bypass reCAPTCHA and use test phone numbers ──
# Firebase Console → Authentication → Sign-in method → Phone → Phone numbers for testing
# NEVER set this in production.
NEXT_PUBLIC_FIREBASE_TEST_MODE=false
